<!-- COOKIE BANNER -->
<div id="cookie-banner" style="display:none;">
  <div style="flex:1;min-width:260px;">
    <p style="font-size:13px;color:#e6edf3;margin-bottom:4px;font-weight:500;">🍪 We use cookies</p>
    <p style="font-size:12px;color:#8b949e;line-height:1.6;">We use cookies for personalised ads (Google AdSense) and analytics. See our <a href="privacy-policy.html" style="color:#d4a843;text-decoration:none;">Privacy Policy</a>.</p>
  </div>
  <div style="display:flex;gap:10px;flex-shrink:0;">
    <button onclick="declineCookies()" style="height:36px;padding:0 18px;border-radius:8px;border:1px solid rgba(255,255,255,.14);background:transparent;color:#8b949e;font-family:'DM Sans',sans-serif;font-size:13px;cursor:pointer;">Decline</button>
    <button onclick="acceptCookies()" style="height:36px;padding:0 18px;border-radius:8px;border:none;background:#d4a843;color:#0d1117;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;cursor:pointer;">Accept all</button>
  </div>
</div>

<script>
// ── DATA ──
const TAX_BRACKETS=[{min:0,max:45000,rate:.15},{min:45000,max:135000,rate:.325},{min:135000,max:190000,rate:.37},{min:190000,max:Infinity,rate:.45}];
const EXPENSES_CONFIG=[
  {id:'rent',icon:'🏠',color:'#58a6ff',label:'Rent / Accommodation',default:1200},
  {id:'food',icon:'🛒',color:'#d4a843',label:'Food & Groceries',default:400},
  {id:'eating',icon:'🍜',color:'#e891a0',label:'Eating Out & Drinks',default:150},
  {id:'shopping',icon:'🛍️',color:'#a78bfa',label:'Shopping & Clothing',default:100},
  {id:'electricity',icon:'⚡',color:'#fbbf24',label:'Electricity',default:80},
  {id:'water',icon:'💧',color:'#34d399',label:'Water Bill',default:40},
  {id:'transport',icon:'🚌',color:'#60a5fa',label:'Transport',default:120},
  {id:'phone',icon:'📱',color:'#a3e635',label:'Phone Plan',default:30},
  {id:'other',icon:'📦',color:'#8b949e',label:'Other Expenses',default:100},
];
const CITY_PRESETS={
  sydney:   {rent:1800,food:450,eating:200,shopping:120,electricity:90,water:50,transport:160,phone:30,other:120},
  melbourne:{rent:1600,food:420,eating:180,shopping:110,electricity:85,water:45,transport:150,phone:30,other:110},
  brisbane: {rent:1400,food:380,eating:160,shopping:100,electricity:100,water:50,transport:130,phone:30,other:100},
  perth:    {rent:1300,food:360,eating:150,shopping:100,electricity:95,water:45,transport:120,phone:30,other:90},
  regional: {rent:200,food:280,eating:80,shopping:60,electricity:60,water:30,transport:80,phone:30,other:60},
};
const CITY_LIST=[{key:'sydney',name:'Sydney',flag:'🏙'},{key:'melbourne',name:'Melbourne',flag:'🏛'},{key:'brisbane',name:'Brisbane',flag:'☀️'},{key:'perth',name:'Perth',flag:'🌊'},{key:'regional',name:'Regional',flag:'🌾'}];
const PENALTY_MULTIPLIERS={
  hospitality:[{label:'Weekday (Mon–Fri)',mult:1},{label:'Saturday',mult:1.25},{label:'Sunday',mult:1.5},{label:'Public Holiday',mult:2.25},{label:'Evening (after 9pm)',mult:1.15}],
  retail:     [{label:'Weekday (Mon–Fri)',mult:1},{label:'Saturday',mult:1.25},{label:'Sunday',mult:1.5},{label:'Public Holiday',mult:2.25},{label:'Evening (after 6pm)',mult:1.15}],
  fastfood:   [{label:'Weekday (Mon–Fri)',mult:1},{label:'Saturday',mult:1.25},{label:'Sunday',mult:1.5},{label:'Public Holiday',mult:2.5},{label:'Evening (after 9pm)',mult:1.15}],
  farm:       [{label:'Weekday (Mon–Fri)',mult:1},{label:'Saturday',mult:1.1},{label:'Sunday',mult:1.1},{label:'Public Holiday',mult:2},{label:'Overtime (>38hrs)',mult:1.5}],
};
const FX_RATES={GBP:.51,EUR:.60,USD:.65,PHP:37.5,JPY:99,KRW:870,NZD:1.09,CAD:.90,ZAR:12.1,BRL:3.3,MXN:11.2,SGD:.88,HKD:5.07,INR:54,THB:23,TWD:20.7};
const FX_SYMBOLS={GBP:'£',EUR:'€',USD:'$',PHP:'₱',JPY:'¥',KRW:'₩',NZD:'NZ$',CAD:'CA$',ZAR:'R',BRL:'R$',MXN:'MX$',SGD:'S$',HKD:'HK$',INR:'₹',THB:'฿',TWD:'NT$'};

// ── STATE ──
let period='hourly', mlExempt=true, superRate=.115, trMonths=12;

// ── HELPERS ──
const fmt=n=>'$'+Math.round(n).toLocaleString('en-AU');
const fmtFx=(n,sym)=>sym+n.toLocaleString('en-AU',{maximumFractionDigits:0});
const v=id=>parseFloat(document.getElementById(id).value)||0;
const CIRC=2*Math.PI*52;

function calcTax(income){
  let tax=0;
  for(const b of TAX_BRACKETS){
    if(income<=b.min)break;
    tax+=(Math.min(income,b.max)-b.min)*b.rate;
  }
  return tax;
}
function annualGross(){
  const inc=v('income-input'),h=v('hours-input'),j2=v('job2-input');
  let base=0;
  if(period==='hourly')base=inc*h*52;
  else if(period==='weekly')base=inc*52;
  else if(period==='fortnightly')base=inc*26;
  else base=inc;
  return base+j2*52;
}
function totalMonthlyExp(){return EXPENSES_CONFIG.reduce((s,e)=>s+v('exp-'+e.id),0);}
function donutArc(id,frac,offset){
  const el=document.getElementById(id);
  el.setAttribute('stroke-dasharray',CIRC.toFixed(1));
  el.setAttribute('stroke-dashoffset',(CIRC-frac*CIRC+offset*CIRC).toFixed(1));
}

// ── BUILD EXPENSE ROWS ──
const expList=document.getElementById('expense-list');
EXPENSES_CONFIG.forEach(e=>{
  const row=document.createElement('div');
  row.className='exp-row';
  row.innerHTML=`<div class="exp-icon" style="background:${e.color}22;">${e.icon}</div><div class="exp-name">${e.label}<small>Per month</small></div><div style="position:relative;"><span style="position:absolute;left:6px;top:50%;transform:translateY(-50%);font-size:11px;color:var(--text3);pointer-events:none;">$</span><input type="number" id="exp-${e.id}" class="exp-input" value="${e.default}" min="0" step="1" oninput="updateAll()"></div>`;
  expList.appendChild(row);
});

// ── CITY PRESETS ──
let activeCity=null;
document.querySelectorAll('.city-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    const city=btn.dataset.city;
    if(activeCity===city){btn.classList.remove('active');activeCity=null;return;}
    document.querySelectorAll('.city-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');activeCity=city;
    const p=CITY_PRESETS[city];
    EXPENSES_CONFIG.forEach(e=>{if(p[e.id]!==undefined)document.getElementById('exp-'+e.id).value=p[e.id];});
    updateAll();
  });
});

// ── MAIN UPDATE ──
function updateAll(){
  const gross=annualGross(),tax=calcTax(gross),ml=mlExempt?0:gross*.02;
  const annualNet=gross-tax-ml,monthlyNet=annualNet/12;
  const monthlyExp=totalMonthlyExp(),annualExp=monthlyExp*12;
  const monthlySave=monthlyNet-monthlyExp;
  const savePct=monthlyNet>0?monthlySave/monthlyNet:0;
  const expPct=monthlyNet>0?monthlyExp/monthlyNet:0;
  const eff=gross>0?tax/gross:0;

  // INCOME
  document.getElementById('r-gross').textContent=fmt(gross);
  document.getElementById('r-gross-wk').textContent=fmt(gross/52)+' / week';
  document.getElementById('r-tax').textContent=fmt(tax);
  document.getElementById('r-eff').textContent=(eff*100).toFixed(1)+'% effective';
  document.getElementById('r-ml').textContent=fmt(ml);
  document.getElementById('r-net').textContent=fmt(annualNet);
  document.getElementById('r-net-wk').textContent=fmt(annualNet/52)+' / week';
  document.getElementById('r-net-mo').textContent=fmt(monthlyNet);
  document.getElementById('r-super').textContent=fmt(gross*superRate);

  // ── BRACKET VISUALISER: B + C ──
  const BK_COLORS=['#3fb950','#58a6ff','#d4a843','#f85149'];
  const BK_MAX=200000;
  const activeBktIdx=TAX_BRACKETS.reduce((ai,b,i)=>gross>b.min?i:ai,-1);

  // B — Stacked bar
  const track=document.getElementById('bk-bar-track');
  track.innerHTML='';
  const displaySegs=[
    {min:0,      max:45000,  rate:.15,  label:'15%'},
    {min:45000,  max:135000, rate:.325, label:'32.5%'},
    {min:135000, max:190000, rate:.37,  label:'37%'},
    {min:190000, max:BK_MAX, rate:.45,  label:'45%'},
  ];
  displaySegs.forEach((seg,i)=>{
    const w=(seg.max-seg.min)/BK_MAX*100;
    const filled=gross>seg.min;
    const col=BK_COLORS[i];
    const el=document.createElement('div');
    el.className='bk-seg';
    el.style.cssText=`flex:0 0 ${w.toFixed(2)}%;background:${filled?col:col+'22'};border-right:${i<3?'1px solid rgba(0,0,0,.15)':'none'};`;
    el.innerHTML=`<span style="color:${filled?'#fff':col};">${seg.label}</span>`;
    track.appendChild(el);
  });

  // Pin position
  const pinPct=Math.min(Math.max(gross/BK_MAX*100,0),99);
  const pin=document.getElementById('bk-pin');
  pin.style.left=pinPct.toFixed(2)+'%';
  document.getElementById('bk-pin-label').textContent=fmt(gross);

  // Legend
  const legend=document.getElementById('bk-legend');
  legend.innerHTML=displaySegs.map((s,i)=>`<div class="bk-leg"><div class="bk-leg-dot" style="background:${BK_COLORS[i]};"></div><span>$${(s.min/1000).toFixed(0)}k${s.max===BK_MAX?'+':'–$'+(s.max/1000).toFixed(0)+'k'} @ ${s.label}</span></div>`).join('');

  // C — Reference table
  let cumTax=0;
  let tRows='';
  TAX_BRACKETS.forEach((b,i)=>{
    const col=BK_COLORS[i];
    const sliceAmt=gross>b.min?Math.min(gross,b.max===Infinity?gross:b.max)-b.min:0;
    const sliceTax=sliceAmt*b.rate;
    cumTax+=sliceTax;
    const maxLbl=b.max===Infinity?'∞':'$'+b.max.toLocaleString();
    const isActive=i===activeBktIdx&&gross>0;
    const isInactive=gross<=b.min;
    const rowCls=isActive?'bk-active':isInactive?'bk-inactive':'';
    tRows+=`<tr class="${rowCls}">
      <td>$${b.min.toLocaleString()} – ${maxLbl}</td>
      <td><span class="bk-rate-pill" style="background:${col}22;color:${col};">${(b.rate*100).toFixed(1)}%</span></td>
      <td>${sliceAmt>0?fmt(sliceAmt):'—'}</td>
      <td>${sliceTax>0?fmt(sliceTax):'—'}</td>
      <td>${cumTax>0?fmt(cumTax):'—'}</td>
    </tr>`;
  });
  if(!mlExempt&&ml>0){
    tRows+=`<tr><td colspan="3" style="color:var(--text3);">Medicare levy</td><td style="color:#f85149;">${fmt(ml)}</td><td style="color:#f85149;">${fmt(tax+ml)}</td></tr>`;
  }
  document.getElementById('bk-tbody').innerHTML=tRows;

  // INCOME SUMMARY BARS (all secondary tabs)
  const hrlyAfterTaxVal = annualNet/(52*(v('hours-input')||38));
  const setIS=(sfx,g,t,n)=>{
    const eg=document.getElementById('is-gross-'+sfx);
    const et=document.getElementById('is-tax-'+sfx);
    const en=document.getElementById('is-net-'+sfx);
    if(eg)eg.textContent=fmt(g);
    if(et)et.textContent=fmt(t);
    if(en)en.textContent=fmt(n);
  };
  setIS('super',gross,tax,annualNet);
  setIS('penalty',gross,tax,annualNet);
  setIS('goal',gross,tax,annualNet);
  setIS('currency',gross,tax,annualNet);
  setIS('sy',gross,tax,annualNet);
  setIS('tr',gross,tax,annualNet);
  // weekly net
  ['super','currency','sy'].forEach(sfx=>{const el=document.getElementById('is-wknet-'+sfx);if(el)el.textContent=fmt(annualNet/52);});
  // monthly net
  ['goal','compare'].forEach(sfx=>{const el=document.getElementById('is-monet-'+sfx);if(el)el.textContent=fmt(monthlyNet);});
  // compare gross
  const ecg=document.getElementById('is-gross-compare');if(ecg)ecg.textContent=fmt(gross);
  const ecr=document.getElementById('is-taxrate-compare');if(ecr)ecr.textContent=(eff*100).toFixed(1)+'%';
  // goal net + expenses
  const egn=document.getElementById('is-net-goal');if(egn)egn.textContent=fmt(annualNet);
  const ege=document.getElementById('is-exp-goal');if(ege)ege.textContent=fmt(monthlyExp);
  // penalty hourly
  const eph=document.getElementById('is-hrly-penalty');if(eph)eph.textContent='$'+hrlyAfterTaxVal.toFixed(2)+'/hr';
  // sy hourly
  const esh=document.getElementById('is-hrly-sy');if(esh)esh.textContent='$'+(v('income-input')||0).toFixed(2)+'/hr';
  // tr effective rate
  const ete=document.getElementById('is-eff-tr');if(ete)ete.textContent=(eff*100).toFixed(1)+'%';

  // BUDGET
  document.getElementById('total-exp-mo').textContent=fmt(monthlyExp);
  document.getElementById('total-exp-yr').textContent=fmt(annualExp);
  document.getElementById('s-mo-net').textContent=fmt(monthlyNet);
  document.getElementById('s-mo-spend').textContent=fmt(monthlyExp);
  document.getElementById('s-mo-save').textContent=fmt(monthlySave);
  document.getElementById('s-mo-save').className='m-value '+(monthlySave>=0?'c-green':'c-red');
  document.getElementById('s-save-pct').textContent=(savePct*100).toFixed(1)+'% of income';
  const barPct=Math.min(expPct*100,100);
  const barColor=expPct<.6?'var(--green)':expPct<.85?'var(--gold)':'var(--red)';
  document.getElementById('exp-bar').style.cssText=`width:${barPct.toFixed(1)}%;background:${barColor};`;
  document.getElementById('exp-pct-label').textContent=(expPct*100).toFixed(1)+'%';
  const chip=document.getElementById('status-chip'),msg=document.getElementById('status-msg');
  if(monthlySave<0){chip.className='chip chip-red';chip.textContent='● Over budget';msg.textContent='Expenses exceed income.';}
  else if(savePct<.2){chip.className='chip chip-gold';chip.textContent='● Tight';msg.textContent='Savings below 20%.';}
  else{chip.className='chip chip-green';chip.textContent='● Healthy';msg.textContent=`Saving ${(savePct*100).toFixed(0)}% of net income!`;}
  ['3','6','9','12'].forEach(m=>{document.getElementById('proj-'+m).textContent=fmt(Math.max(0,monthlySave)*parseInt(m));});
  const tF=gross>0?(tax+ml)/gross:0,eF=gross>0?annualExp/gross:0,sF=Math.max(0,1-tF-eF);
  donutArc('donut-tax',tF,0);donutArc('donut-exp',eF,tF);donutArc('donut-sav',sF,tF+eF);
  document.getElementById('donut-pct').textContent=(sF*100).toFixed(0)+'%';

  // SUPER
  const supW=v('super-weeks'),wkG=gross/52,supG=wkG*supW*superRate;
  document.getElementById('sup-gross').textContent=fmt(supG);
  document.getElementById('sup-tax').textContent=fmt(supG*.65);
  document.getElementById('sup-net').textContent=fmt(supG*.35);
  document.getElementById('sup-weekly').textContent=fmt(wkG*superRate);

  // PENALTY RATES
  const prBase=v('pr-base'),award=document.getElementById('pr-award').value;
  document.getElementById('pr-tbody').innerHTML=PENALTY_MULTIPLIERS[award].map(r=>`<tr><td>${r.label}</td><td>${r.mult.toFixed(2)}×</td><td>$${(prBase*r.mult).toFixed(2)}/hr</td><td>${fmt(prBase*r.mult*8)}</td></tr>`).join('');

  // GOAL
  const goalAmt=v('goal-amount'),goalMo=v('goal-months')||1,goalExp=v('goal-expenses');
  document.getElementById('goal-expenses').value=Math.round(monthlyExp)||document.getElementById('goal-expenses').value;
  const reqMoSave=goalAmt/goalMo,reqMoNet=reqMoSave+monthlyExp,reqAnnualNet=reqMoNet*12;
  let reqGross=reqAnnualNet/.7;
  for(let i=0;i<20;i++){const t=calcTax(reqGross)+(mlExempt?0:reqGross*.02);reqGross=reqAnnualNet+t;}
  const reqRate=reqGross/(38*52),curRate=v('income-input');
  const reqHours=curRate>0?reqGross/(curRate*52):0;
  document.getElementById('goal-mo-net').textContent=fmt(reqMoNet);
  document.getElementById('goal-gross').textContent=fmt(reqGross);
  document.getElementById('goal-rate').textContent='$'+reqRate.toFixed(2)+'/hr';
  document.getElementById('goal-hours').textContent=Math.ceil(reqHours)+' hrs';
  document.getElementById('goal-breakdown').innerHTML=
    `<div class="brow"><div class="brow-label">Savings per month</div><div class="brow-val c-green">${fmt(reqMoSave)}</div></div>
     <div class="brow"><div class="brow-label">Total over ${goalMo} months</div><div class="brow-val c-gold">${fmt(goalAmt)}</div></div>
     <div class="brow"><div class="brow-label">Required monthly net</div><div class="brow-val c-blue">${fmt(reqMoNet)}</div></div>`;

  // CITY COMPARE
  document.getElementById('city-compare-grid').innerHTML=CITY_LIST.map(city=>{
    const p=CITY_PRESETS[city.key],ce=Object.values(p).reduce((a,b)=>a+b,0),cs=monthlyNet-ce,pct=monthlyNet>0?cs/monthlyNet:0;
    const col=cs>0?'var(--green)':'var(--red)';
    return `<div class="metric" style="border:1px solid var(--border);">
      <div style="font-size:1.2rem;margin-bottom:4px;">${city.flag}</div>
      <div style="font-size:13px;font-weight:600;color:var(--text);margin-bottom:8px;">${city.name}</div>
      <div class="m-label">Monthly expenses</div><div class="m-value" style="font-size:1rem;color:var(--red);">${fmt(ce)}</div>
      <div class="m-label" style="margin-top:8px;">Monthly savings</div><div class="m-value" style="font-size:1rem;color:${col};">${fmt(cs)}</div>
      <div class="m-sub">${(pct*100).toFixed(0)}% saved</div>
      <div class="bar-bg" style="margin-top:8px;"><div style="height:100%;border-radius:99px;width:${Math.max(0,Math.min(pct*100,100)).toFixed(1)}%;background:${col};"></div></div>
    </div>`;
  }).join('');

  // CURRENCY
  const fx=v('fx-rate'),curr=document.getElementById('currency-select').value,sym=FX_SYMBOLS[curr];
  document.getElementById('fx-gross').textContent=fmtFx(gross*fx,sym);
  document.getElementById('fx-gross-aud').textContent=fmt(gross)+' AUD';
  document.getElementById('fx-net').textContent=fmtFx(annualNet*fx,sym);
  document.getElementById('fx-net-aud').textContent=fmt(annualNet)+' AUD';
  document.getElementById('fx-weekly').textContent=fmtFx((annualNet/52)*fx,sym);
  document.getElementById('fx-weekly-aud').textContent=fmt(annualNet/52)+' AUD';
  document.getElementById('fx-savings').textContent=fmtFx(Math.max(0,monthlySave)*fx,sym);
  document.getElementById('fx-savings-aud').textContent=fmt(Math.max(0,monthlySave))+' AUD';
  const hrly=annualNet/(52*(v('hours-input')||38));
  document.getElementById('fx-hourly').textContent=sym+(hrly*fx).toFixed(2);
  document.getElementById('fx-hourly-label').textContent=`per hour after tax (in ${curr})`;

  // 2ND YEAR
  const syDays=v('sy-days'),remaining=Math.max(0,88-syDays),syWeeks=remaining/7;
  const syCost=v('sy-transport')+(syWeeks*(v('sy-rent')+v('sy-living'))),syEarn=syWeeks*v('sy-rate')*38,syOut=syEarn-syCost;
  document.getElementById('sy-remaining').textContent=remaining;
  document.getElementById('sy-weeks').textContent=syWeeks.toFixed(1);
  document.getElementById('sy-cost').textContent=fmt(syCost);
  document.getElementById('sy-earn').textContent=fmt(syEarn);
  document.getElementById('sy-outcome').textContent=fmt(syOut);
  document.getElementById('sy-outcome').className='m-value '+(syOut>=0?'c-green':'c-red');
  document.getElementById('sy-outcome-label').textContent=syOut>=0?'Net positive — you\'ll save while qualifying!':'You\'ll spend more than you earn during regional work.';
  const prog=Math.min(syDays/88*100,100);
  document.getElementById('sy-bar').style.width=prog.toFixed(1)+'%';
  document.getElementById('sy-prog-label').textContent=`${Math.min(syDays,88)} of 88 days`;
  document.getElementById('sy-prog-pct').textContent=prog.toFixed(0)+'%';
  document.getElementById('sy-status').textContent=remaining<=0?'✅ Eligible for second year visa!':remaining+' days remaining to qualify.';

  // TAX RETURN
  const trWith=v('tr-withheld'),trDed=v('tr-deductions'),trGross=(gross/12)*trMonths;
  const trTaxable=Math.max(0,trGross-trDed),trOwed=calcTax(trTaxable)+(mlExempt?0:trTaxable*.02);
  const trDiff=trWith-trOwed;
  document.getElementById('tr-taxable').textContent=fmt(trTaxable);
  document.getElementById('tr-owed').textContent=fmt(trOwed);
  document.getElementById('tr-withheld-display').textContent=fmt(trWith);
  document.getElementById('tr-result').textContent=fmt(Math.abs(trDiff));
  document.getElementById('tr-result').className='m-value '+(trDiff>=0?'c-green':'c-red');
  document.getElementById('tr-result-label').textContent=trDiff>=0?'Estimated refund':'You may owe';
  document.getElementById('tr-result-sub').textContent=trDiff>=0?'The ATO owes you this':'Pay this when you lodge';

  buildShareUrl();
  updatePayslip();
  updateMilestones();
}

// ── SHARE URL ──
function buildShareUrl(){
  try{
    const p=new URLSearchParams();
    p.set('p',period);p.set('i',v('income-input'));p.set('h',v('hours-input'));p.set('j2',v('job2-input'));p.set('ml',mlExempt?'0':'1');
    EXPENSES_CONFIG.forEach(e=>p.set('e_'+e.id,v('exp-'+e.id)));
    document.getElementById('share-url').textContent=window.location.origin+window.location.pathname+'?'+p.toString();
  }catch(e){}
}
function copyShareUrl(){
  const url=document.getElementById('share-url').textContent;
  navigator.clipboard.writeText(url).then(()=>{
    const btn=document.querySelector('.copy-btn');btn.textContent='Copied!';
    setTimeout(()=>btn.textContent='Copy',2000);
  });
}
function loadFromUrl(){
  try{
    const p=new URLSearchParams(window.location.search);
    if(!p.has('i'))return;
    const per=p.get('p');
    if(per){
      period=per;
      document.querySelectorAll('#period-toggle .toggle-btn').forEach(b=>b.classList.toggle('active',b.dataset.period===per));
      const labels={hourly:'Hourly rate (AUD)',weekly:'Weekly income (AUD)',fortnightly:'Fortnightly income (AUD)',annual:'Annual income (AUD)'};
      document.getElementById('income-label').textContent=labels[per];
      document.getElementById('hours-field').style.display=per==='hourly'?'block':'none';
    }
    ['i','h','j2'].forEach(k=>{const map={i:'income-input',h:'hours-input',j2:'job2-input'};if(p.has(k))document.getElementById(map[k]).value=p.get(k);});
    if(p.has('ml')){mlExempt=p.get('ml')==='0';document.querySelectorAll('#medicare-toggle .toggle-btn').forEach(b=>b.classList.toggle('active',(b.dataset.ml==='exempt')===mlExempt));}
    EXPENSES_CONFIG.forEach(e=>{if(p.has('e_'+e.id))document.getElementById('exp-'+e.id).value=p.get('e_'+e.id);});
  }catch(e){}
}

// ── EVENT LISTENERS ──
document.querySelectorAll('#period-toggle .toggle-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('#period-toggle .toggle-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');period=btn.dataset.period;
    const labels={hourly:'Hourly rate (AUD)',weekly:'Weekly income (AUD)',fortnightly:'Fortnightly income (AUD)',annual:'Annual income (AUD)'};
    document.getElementById('income-label').textContent=labels[period];
    document.getElementById('hours-field').style.display=period==='hourly'?'block':'none';
    updateAll();
  });
});
document.querySelectorAll('#medicare-toggle .toggle-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{document.querySelectorAll('#medicare-toggle .toggle-btn').forEach(b=>b.classList.remove('active'));btn.classList.add('active');mlExempt=btn.dataset.ml==='exempt';updateAll();});
});
document.querySelectorAll('#super-rate-toggle .toggle-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{document.querySelectorAll('#super-rate-toggle .toggle-btn').forEach(b=>b.classList.remove('active'));btn.classList.add('active');superRate=parseFloat(btn.dataset.rate);updateAll();});
});
document.querySelectorAll('#tr-period-toggle .toggle-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{document.querySelectorAll('#tr-period-toggle .toggle-btn').forEach(b=>b.classList.remove('active'));btn.classList.add('active');trMonths=parseInt(btn.dataset.months);updateAll();});
});
['income-input','hours-input','job2-input','pr-base','goal-amount','goal-months','goal-expenses','sy-days','sy-transport','sy-rent','sy-living','sy-rate','super-weeks','tr-withheld','tr-deductions','fx-rate'].forEach(id=>{
  const el=document.getElementById(id);if(el)el.addEventListener('input',updateAll);
});
document.getElementById('pr-award').addEventListener('change',updateAll);
document.getElementById('currency-select').addEventListener('change',()=>{
  const curr=document.getElementById('currency-select').value;
  document.getElementById('fx-curr-label').textContent=curr;
  document.getElementById('fx-rate').value=FX_RATES[curr]||.65;
  updateAll();
});
document.querySelectorAll('.main-tab').forEach(tab=>{
  tab.addEventListener('click',()=>{
    document.querySelectorAll('.main-tab').forEach(t=>t.classList.remove('active'));
    document.querySelectorAll('.page-section').forEach(s=>s.classList.remove('active'));
    tab.classList.add('active');
    document.getElementById('tab-'+tab.dataset.tab).classList.add('active');
  });
});

// ── PAYSLIP CHECK ──
let psPeriod='weekly', psTfn=true;

document.querySelectorAll('#ps-period-toggle .toggle-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('#ps-period-toggle .toggle-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active'); psPeriod=btn.dataset.psperiod; updatePayslip();
  });
});
document.querySelectorAll('#ps-tfn-toggle .toggle-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('#ps-tfn-toggle .toggle-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active'); psTfn=btn.dataset.tfn==='yes'; updatePayslip();
  });
});

function updatePayslip(){
  const gross=parseFloat(document.getElementById('ps-gross').value)||0;
  const withheld=parseFloat(document.getElementById('ps-withheld').value)||0;
  const periods={weekly:52,fortnightly:26,monthly:12};
  const mult=periods[psPeriod]||52;
  const annualised=gross*mult;
  const correctAnnual=psTfn?calcTax(annualised)+(mlExempt?0:annualised*.02):annualised*.45;
  const correctPeriod=correctAnnual/mult;
  const diff=withheld-correctPeriod;
  const absDiff=Math.abs(diff);

  document.getElementById('ps-r-gross').textContent=fmt(gross);
  document.getElementById('ps-r-annual').textContent='~'+fmt(annualised)+' annualised';
  document.getElementById('ps-r-withheld').textContent=fmt(withheld);
  document.getElementById('ps-r-correct').textContent=fmt(correctPeriod);
  document.getElementById('ps-r-diff').textContent=(diff>=0?'+':'-')+fmt(absDiff);

  const diffEl=document.getElementById('ps-r-diff');
  const subEl=document.getElementById('ps-r-diff-sub');
  let verdict='';

  if(gross===0){
    diffEl.textContent='—'; diffEl.className='m-value'; subEl.textContent='Enter payslip figures';
    document.getElementById('ps-verdict').innerHTML=''; return;
  }
  if(Math.abs(diff)<1){
    diffEl.className='m-value c-green'; subEl.textContent='Spot on';
    verdict=`<div class="ps-result ps-status-ok"><div class="ps-icon">✅</div><div><div class="ps-title">Tax looks correct</div><div class="ps-desc">Your employer withheld ${fmt(withheld)}, which matches the ATO WHV rate of ${fmt(correctPeriod)} for this pay period. No action needed.</div></div></div>`;
  } else if(diff>0){
    diffEl.className='m-value c-blue'; subEl.textContent='Over-withheld';
    verdict=`<div class="ps-result ps-status-over"><div class="ps-icon">💙</div><div><div class="ps-title">You've been over-withheld by ${fmt(absDiff)}</div><div class="ps-desc">Your employer took ${fmt(diff)} more than required. You'll receive this back as a refund when you lodge your tax return. Set this aside — it's yours.</div></div></div>`;
  } else {
    diffEl.className='m-value c-red'; subEl.textContent='Under-withheld';
    verdict=`<div class="ps-result ps-status-under"><div class="ps-icon">⚠️</div><div><div class="ps-title">You've been under-withheld by ${fmt(absDiff)}</div><div class="ps-desc">Your employer only took ${fmt(withheld)} but should have taken ${fmt(correctPeriod)}. You'll owe ${fmt(absDiff)} extra at tax return time. Set aside ${fmt(absDiff)} per ${psPeriod} pay to cover it.</div></div></div>`;
  }
  document.getElementById('ps-verdict').innerHTML=verdict;

  // update income summary
  const gross2=annualGross(), tax2=calcTax(gross2), net2=gross2-tax2-(mlExempt?0:gross2*.02);
  const el1=document.getElementById('is-gross-payslip'); if(el1)el1.textContent=fmt(gross2);
  const el2=document.getElementById('is-wktax-payslip'); if(el2)el2.textContent=fmt(tax2/52);
  const el3=document.getElementById('is-wknet-payslip'); if(el3)el3.textContent=fmt(net2/52);
}

// ── HOURS LOG ──
const DAYS_OF_WEEK=['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'];
const DAY_TYPE_MULT={
  hospitality:[1,1,1,1,1,1.25,1.5],
  retail:     [1,1,1,1,1,1.25,1.5],
  fastfood:   [1,1,1,1,1,1.25,1.5],
  farm:       [1,1,1,1,1,1.1,1.1],
};
const DAY_LABELS=['Weekday','Weekday','Weekday','Weekday','Weekday','Saturday','Sunday'];
const DAY_CLASSES=['type-weekday','type-weekday','type-weekday','type-weekday','type-weekday','type-saturday','type-sunday'];

function buildDayRows(){
  const wrap=document.getElementById('tl-day-rows');
  wrap.innerHTML='';
  DAYS_OF_WEEK.forEach((day,i)=>{
    const row=document.createElement('div');
    row.className='day-row';
    const isPH=i<5;
    row.innerHTML=`
      <div style="display:flex;flex-direction:column;gap:3px;">
        <span class="day-label">${day}</span>
        <span class="day-type ${DAY_CLASSES[i]}" id="tl-dtype-${i}">${DAY_LABELS[i]}</span>
      </div>
      <input type="number" class="tl-hrs-input" id="tl-hrs-${i}" value="0" min="0" max="24" step="0.5" oninput="updateTimelog()">
      <div class="day-earn" id="tl-earn-${i}">$0</div>
      ${isPH?`<button class="ph-toggle" id="tl-ph-${i}" onclick="togglePH(${i})">Public holiday</button>`:'<div></div>'}`;
    wrap.appendChild(row);
  });
  // Set today's week
  const today=new Date();
  const mon=new Date(today);
  mon.setDate(today.getDate()-((today.getDay()+6)%7));
  document.getElementById('tl-week-start').value=mon.toISOString().split('T')[0];
}

const phDays=new Set();
function togglePH(i){
  const btn=document.getElementById('tl-ph-'+i);
  if(phDays.has(i)){phDays.delete(i);btn.classList.remove('active');}
  else{phDays.add(i);btn.classList.add('active');}
  updateTimelog();
}

const PH_MULT={hospitality:2.25,retail:2.25,fastfood:2.5,farm:2.0};

function updateTimelog(){
  const award=document.getElementById('tl-award').value;
  const baseRate=v('income-input')||0;
  const mults=DAY_TYPE_MULT[award]||DAY_TYPE_MULT.hospitality;
  let totalHrs=0, totalGross=0, stdGross=0;
  const breakdown=[];

  DAYS_OF_WEEK.forEach((day,i)=>{
    const hrs=parseFloat(document.getElementById('tl-hrs-'+i).value)||0;
    const isPH=phDays.has(i);
    const mult=isPH?PH_MULT[award]:mults[i];
    const rate=baseRate*mult;
    const earn=hrs*rate;
    const stdEarn=hrs*baseRate;
    totalHrs+=hrs; totalGross+=earn; stdGross+=stdEarn;
    document.getElementById('tl-earn-'+i).textContent=fmt(earn);
    const dtype=document.getElementById('tl-dtype-'+i);
    if(isPH){dtype.textContent='Public holiday';dtype.className='day-type type-holiday';}
    else{dtype.textContent=DAY_LABELS[i];dtype.className='day-type '+DAY_CLASSES[i];}
    if(hrs>0) breakdown.push({day,hrs,mult,rate,earn});
  });

  const annualised=totalGross*52;
  const weekTax=calcTax(annualised)/52;
  const weekNet=totalGross-weekTax;
  const bonus=totalGross-stdGross;

  document.getElementById('tl-total-hrs').textContent=totalHrs.toFixed(1)+' hrs';
  document.getElementById('tl-ot-note').textContent=totalHrs>38?`${(totalHrs-38).toFixed(1)} hrs overtime`:'Standard week';
  document.getElementById('tl-gross').textContent=fmt(totalGross);
  document.getElementById('tl-tax').textContent=fmt(weekTax);
  document.getElementById('tl-net').textContent=fmt(weekNet);
  document.getElementById('tl-bonus').textContent=fmt(bonus);
  document.getElementById('tl-annual').textContent=fmt(annualised);

  // income summary
  const el1=document.getElementById('is-rate-timelog');if(el1)el1.textContent='$'+baseRate.toFixed(2)+'/hr';
  const el2=document.getElementById('is-std-timelog');if(el2)el2.textContent=fmt(baseRate*38);

  // breakdown table
  const bd=document.getElementById('tl-breakdown');
  if(breakdown.length===0){bd.innerHTML='<p style="font-size:13px;color:var(--text3);text-align:center;padding:.5rem;">Enter hours above to see breakdown.</p>';return;}
  bd.innerHTML=`<table style="width:100%;border-collapse:collapse;font-size:12px;">
    <thead><tr style="background:var(--bg3);">
      <th style="padding:6px 10px;text-align:left;color:var(--text3);font-size:10px;font-weight:600;letter-spacing:.07em;text-transform:uppercase;border-bottom:1px solid var(--border);">Day</th>
      <th style="padding:6px 10px;text-align:right;color:var(--text3);font-size:10px;font-weight:600;letter-spacing:.07em;text-transform:uppercase;border-bottom:1px solid var(--border);">Hours</th>
      <th style="padding:6px 10px;text-align:right;color:var(--text3);font-size:10px;font-weight:600;letter-spacing:.07em;text-transform:uppercase;border-bottom:1px solid var(--border);">Rate</th>
      <th style="padding:6px 10px;text-align:right;color:var(--text3);font-size:10px;font-weight:600;letter-spacing:.07em;text-transform:uppercase;border-bottom:1px solid var(--border);">Multiplier</th>
      <th style="padding:6px 10px;text-align:right;color:var(--text3);font-size:10px;font-weight:600;letter-spacing:.07em;text-transform:uppercase;border-bottom:1px solid var(--border);">Earned</th>
    </tr></thead>
    <tbody>${breakdown.map(r=>`<tr>
      <td style="padding:8px 10px;border-bottom:1px solid var(--border);color:var(--text2);">${r.day}</td>
      <td style="padding:8px 10px;border-bottom:1px solid var(--border);color:var(--text2);text-align:right;">${r.hrs.toFixed(1)}</td>
      <td style="padding:8px 10px;border-bottom:1px solid var(--border);color:var(--text2);text-align:right;">$${r.rate.toFixed(2)}</td>
      <td style="padding:8px 10px;border-bottom:1px solid var(--border);color:var(--gold);text-align:right;font-weight:500;">${r.mult.toFixed(2)}×</td>
      <td style="padding:8px 10px;border-bottom:1px solid var(--border);color:var(--gold);text-align:right;font-weight:500;">${fmt(r.earn)}</td>
    </tr>`).join('')}
    <tr style="background:var(--bg3);">
      <td colspan="4" style="padding:8px 10px;font-weight:500;color:var(--text);">Total</td>
      <td style="padding:8px 10px;font-weight:600;color:var(--gold);text-align:right;">${fmt(totalGross)}</td>
    </tr></tbody></table>`;
}


// ── MILESTONES ──
const MILESTONES=[
  {emoji:'✈️', name:'Flight home (UK/Europe)',   cost:1800},
  {emoji:'🏝', name:'Bali trip (1 week)',         cost:1200},
  {emoji:'🤿', name:'Great Barrier Reef trip',    cost:600},
  {emoji:'🦘', name:'East Coast road trip',       cost:1500},
  {emoji:'🏕', name:'Week in Cairns',             cost:900},
  {emoji:'🏍', name:'Buy a motorbike',            cost:3500},
  {emoji:'🚗', name:'Buy a car',                  cost:5000},
  {emoji:'🎓', name:'TEFL/Dive course',           cost:800},
  {emoji:'🏄', name:'Surf lessons (1 week)',       cost:300},
  {emoji:'🎭', name:'Sydney NYE experience',       cost:250},
  {emoji:'🍷', name:'Barossa Valley wine tour',   cost:180},
  {emoji:'🧗', name:'Skydiving jump',             cost:350},
  {emoji:'🛶', name:'Kakadu National Park trip',  cost:700},
  {emoji:'🏔', name:'Snowy Mountains ski week',   cost:1100},
  {emoji:'💰', name:'Emergency fund (1 month)',   cost:0},
  {emoji:'🏠', name:'Bond + 1st month rent',      cost:0},
];

function updateMilestones(){
  const gross=annualGross(), tax=calcTax(gross), ml2=mlExempt?0:gross*.02;
  const annualNet=gross-tax-ml2;
  const monthlyNet=annualNet/12;
  const monthlyExp=totalMonthlyExp();
  const monthlySave=Math.max(0,monthlyNet-monthlyExp);
  const weeklySave=monthlySave/4.33;
  const alreadySaved=parseFloat(document.getElementById('ms-saved').value)||0;

  // update income summary
  const e1=document.getElementById('is-save-ms');if(e1)e1.textContent=fmt(monthlySave);
  const e2=document.getElementById('is-wknet-ms');if(e2)e2.textContent=fmt(annualNet/52);
  const e3=document.getElementById('is-daynet-ms');if(e3)e3.textContent=fmt(annualNet/365);

  // dynamic costs
  const dynMilestones=MILESTONES.map((m,i)=>{
    let cost=m.cost;
    if(i===14)cost=monthlyExp||2000;
    if(i===15)cost=(parseFloat(document.getElementById('exp-rent').value)||1200)*3;
    return {...m,cost};
  });

  const grid=document.getElementById('ms-grid');
  grid.innerHTML=dynMilestones.map(m=>{
    const remaining=Math.max(0,m.cost-alreadySaved);
    const weeks=weeklySave>0?remaining/weeklySave:Infinity;
    const months=weeks/4.33;
    const progPct=m.cost>0?Math.min(alreadySaved/m.cost*100,100):100;
    const color=weeks<=4?'var(--green)':weeks<=12?'var(--gold)':'var(--blue)';
    const timeLabel=remaining===0?'Reached! 🎉':weeks===Infinity?'Save more first':weeks<4?`${weeks.toFixed(1)} weeks`:weeks<52?`${months.toFixed(1)} months`:`${(months/12).toFixed(1)} years`;
    return `<div class="milestone-card">
      <span class="ms-emoji">${m.emoji}</span>
      <div class="ms-name">${m.name}</div>
      <div class="ms-cost">AUD ${fmt(m.cost)}</div>
      <div class="ms-weeks" style="color:${color};">${timeLabel}</div>
      <div class="ms-bar-bg"><div class="ms-bar-fill" style="width:${progPct.toFixed(1)}%;background:${color};"></div></div>
      <div class="ms-sub">${remaining>0?fmt(remaining)+' still needed':fmt(m.cost)+' covered'}</div>
    </div>`;
  }).join('');
}

// ── THEME ──
function toggleTheme(){
  const isLight=document.documentElement.getAttribute('data-theme')==='light';
  const next=isLight?'dark':'light';
  applyTheme(next);
  localStorage.setItem('oz_theme',next);
}
function applyTheme(theme){
  const btn=document.getElementById('theme-btn');
  if(theme==='light'){
    document.documentElement.setAttribute('data-theme','light');
    if(btn)btn.textContent='🌙';
  } else {
    document.documentElement.removeAttribute('data-theme');
    if(btn)btn.textContent='☀️';
  }
}

// ── COOKIES ──
function acceptCookies(){localStorage.setItem('oz_consent','accepted');hideBanner();loadAdsense();}
function declineCookies(){localStorage.setItem('oz_consent','declined');hideBanner();}
function hideBanner(){const b=document.getElementById('cookie-banner');b.style.transition='opacity .3s';b.style.opacity='0';setTimeout(()=>b.style.display='none',300);}
function loadAdsense(){
  ['ad-top','ad-bottom'].forEach(id=>{const el=document.getElementById(id);if(el)el.style.display='block';});
}

// ── INIT ──
window.addEventListener('DOMContentLoaded',()=>{
  const savedTheme=localStorage.getItem('oz_theme')||'dark';
  applyTheme(savedTheme);
  buildDayRows();
  document.getElementById('tl-award').addEventListener('change',updateTimelog);
  document.getElementById('tl-week-start').addEventListener('change',updateTimelog);
  loadFromUrl();updateAll();
  const consent=localStorage.getItem('oz_consent');
  if(!consent)document.getElementById('cookie-banner').style.display='flex';
  else if(consent==='accepted')loadAdsense();
});
</script>
</body>
</html>
