<!DOCTYPE html>
<!-- OzBudget · index.html · v1.4.0 · 2025-03-17 -->
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OzBudget — Australia Working Holiday Calculator</title>
<meta name="description" content="Calculate your real take-home pay, tax, expenses and savings as a Working Holiday Visa holder in Australia. Free WHV tax calculator for subclass 417 & 462.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<!-- GOOGLE ADSENSE: Replace publisher ID once approved -->
<!-- <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX" crossorigin="anonymous"></script> -->
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg:#0d1117; --bg2:#161b22; --bg3:#21262d; --bg4:#2d333b;
  --border:rgba(255,255,255,0.08); --border2:rgba(255,255,255,0.14);
  --text:#e6edf3; --text2:#8b949e; --text3:#6e7681;
  --gold:#d4a843; --gold-dim:rgba(212,168,67,0.12);
  --green:#3fb950; --green-dim:rgba(63,185,80,0.12);
  --red:#f85149; --red-dim:rgba(248,81,73,0.1);
  --blue:#58a6ff; --blue-dim:rgba(88,166,255,0.1);
  --purple:#a78bfa; --purple-dim:rgba(167,139,250,0.1);
  --teal:#34d399; --teal-dim:rgba(52,211,153,0.1);
  --radius:12px; --radius-sm:8px;
}
[data-theme=light] {
  --bg:#f6f8fa; --bg2:#ffffff; --bg3:#f0f2f5; --bg4:#e4e8ed;
  --border:rgba(0,0,0,0.08); --border2:rgba(0,0,0,0.16);
  --text:#1a1f2e; --text2:#57606a; --text3:#8c959f;
  --gold:#b8860b; --gold-dim:rgba(184,134,11,0.1);
  --green:#1a7f37; --green-dim:rgba(26,127,55,0.1);
  --red:#cf222e; --red-dim:rgba(207,34,46,0.08);
  --blue:#0969da; --blue-dim:rgba(9,105,218,0.08);
  --purple:#8250df; --purple-dim:rgba(130,80,223,0.08);
  --teal:#0d7a5f; --teal-dim:rgba(13,122,95,0.08);
}
[data-theme=light] header { background:rgba(246,248,250,.92); }
[data-theme=light] .bk-seg span { color: inherit; }
[data-theme=light] .copy-btn { color:#fff; }
[data-theme=light] .city-btn.active { color:var(--gold); }
[data-theme=light] .main-tab.active { color:var(--gold); }

.theme-btn {
  width:34px; height:34px; border-radius:99px;
  background:var(--bg3); border:1px solid var(--border);
  display:flex; align-items:center; justify-content:center;
  cursor:pointer; font-size:16px; transition:background .15s, border-color .15s;
  flex-shrink:0;
}
.theme-btn:hover { background:var(--bg4); border-color:var(--border2); }
html{scroll-behavior:smooth;}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;}
header{position:sticky;top:0;z-index:100;background:rgba(13,17,23,.9);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);padding:0 1.5rem;height:60px;display:flex;align-items:center;justify-content:space-between;gap:1rem;}
.logo{font-family:'DM Serif Display',serif;font-size:1.3rem;color:var(--gold);letter-spacing:-.02em;text-decoration:none;white-space:nowrap;}
.logo span{color:var(--text2);font-size:.75rem;font-family:'DM Sans',sans-serif;margin-left:8px;font-weight:300;}
.header-nav{display:flex;align-items:center;gap:1.5rem;}
.header-nav a{font-size:13px;color:var(--text2);text-decoration:none;transition:color .15s;}
.header-nav a:hover{color:var(--text);}
.header-badge{font-size:11px;font-weight:500;padding:4px 12px;border-radius:99px;background:var(--gold-dim);color:var(--gold);border:1px solid rgba(212,168,67,.25);white-space:nowrap;}
.hero{padding:3.5rem 1.5rem 2rem;text-align:center;max-width:700px;margin:0 auto;}
.hero h1{font-family:'DM Serif Display',serif;font-size:clamp(2rem,5vw,3.2rem);line-height:1.1;margin-bottom:.8rem;}
.hero h1 em{font-style:italic;color:var(--gold);}
.hero p{font-size:.95rem;color:var(--text2);line-height:1.7;max-width:520px;margin:0 auto;}
.page-section{display:none;}.page-section.active{display:block;}
.container{max-width:1100px;margin:0 auto;padding:0 1.5rem 2rem;}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;align-items:start;}
.grid-3{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:1rem;}
.grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px;}
.span-full{grid-column:1/-1;}
@media(max-width:820px){.grid-2{grid-template-columns:1fr;}.grid-3{grid-template-columns:1fr 1fr;}.grid-4{grid-template-columns:1fr 1fr;}}
@media(max-width:500px){.grid-3{grid-template-columns:1fr;}}
.main-nav{max-width:1100px;margin:0 auto;padding:0 1.5rem 1.5rem;}
.main-nav-tabs{display:flex;gap:6px;overflow-x:auto;padding-bottom:2px;scrollbar-width:none;}
.main-nav-tabs::-webkit-scrollbar{display:none;}
.main-tab{height:36px;padding:0 16px;background:transparent;border:1px solid var(--border);border-radius:99px;color:var(--text2);font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;cursor:pointer;transition:all .15s;white-space:nowrap;}
.main-tab:hover{border-color:var(--border2);color:var(--text);}
.main-tab.active{background:var(--gold-dim);color:var(--gold);border-color:rgba(212,168,67,.35);}
.card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem;transition:border-color .2s;}
.card:hover{border-color:var(--border2);}
.card-title{font-size:11px;font-weight:600;letter-spacing:.1em;color:var(--text3);text-transform:uppercase;margin-bottom:1.2rem;display:flex;align-items:center;gap:8px;}
.ibadge{width:24px;height:24px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:13px;}
.field{margin-bottom:1rem;}
.field label{display:block;font-size:13px;color:var(--text2);margin-bottom:6px;}
.input-wrap{position:relative;display:flex;align-items:center;}
.input-wrap .pfx{position:absolute;left:12px;color:var(--text3);font-size:14px;pointer-events:none;z-index:1;}
input[type=number]{width:100%;height:40px;background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text);font-family:'DM Sans',sans-serif;font-size:14px;padding:0 12px 0 28px;outline:none;transition:border-color .15s,background .15s;-moz-appearance:textfield;}
input[type=number]::-webkit-outer-spin-button,input[type=number]::-webkit-inner-spin-button{-webkit-appearance:none;}
input[type=number]:focus{border-color:var(--gold);background:var(--bg4);}
input[type=number].no-pfx{padding-left:12px;}
select{width:100%;height:40px;background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text);font-family:'DM Sans',sans-serif;font-size:14px;padding:0 12px;outline:none;transition:border-color .15s;cursor:pointer;}
select:focus{border-color:var(--gold);}
.toggle-group{display:flex;background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius-sm);padding:3px;gap:2px;}
.toggle-btn{flex:1;height:32px;background:transparent;border:none;border-radius:6px;color:var(--text2);font-family:'DM Sans',sans-serif;font-size:12px;font-weight:500;cursor:pointer;transition:background .15s,color .15s;white-space:nowrap;}
.toggle-btn.active{background:var(--bg4);color:var(--text);box-shadow:0 1px 3px rgba(0,0,0,.3);}
.metric{background:var(--bg3);border-radius:var(--radius-sm);padding:1rem;border:1px solid var(--border);}
.metric .m-label{font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--text3);font-weight:600;margin-bottom:6px;}
.metric .m-value{font-size:1.35rem;font-weight:500;font-variant-numeric:tabular-nums;line-height:1;}
.metric .m-sub{font-size:11px;color:var(--text3);margin-top:5px;font-variant-numeric:tabular-nums;}
.c-gold{color:var(--gold);}.c-green{color:var(--green);}.c-red{color:var(--red);}.c-blue{color:var(--blue);}.c-purple{color:var(--purple);}.c-teal{color:var(--teal);}
.brow{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid var(--border);font-size:13px;}
.brow:last-child{border-bottom:none;}
.brow-label{color:var(--text2);display:flex;align-items:center;gap:8px;}
.brow-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.brow-val{font-weight:500;font-variant-numeric:tabular-nums;}
.exp-row{display:grid;grid-template-columns:auto 1fr 86px;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid var(--border);}
.exp-row:last-child{border-bottom:none;padding-bottom:0;}
.exp-icon{width:34px;height:34px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;}
.exp-name{font-size:13px;color:var(--text);}
.exp-name small{display:block;font-size:11px;color:var(--text3);margin-top:1px;}
.exp-input{width:86px;height:34px;padding:0 6px 0 18px;font-size:13px;background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text);font-family:'DM Sans',sans-serif;outline:none;-moz-appearance:textfield;transition:border-color .15s;}
.exp-input::-webkit-outer-spin-button,.exp-input::-webkit-inner-spin-button{-webkit-appearance:none;}
.exp-input:focus{border-color:var(--gold);}
.bar-bg{height:8px;background:var(--bg4);border-radius:99px;overflow:hidden;margin:1rem 0 .4rem;}
.bar-fill{height:100%;border-radius:99px;transition:width .5s cubic-bezier(.25,.8,.25,1),background .3s;}
.chip{display:inline-flex;align-items:center;gap:5px;padding:4px 12px;border-radius:99px;font-size:11px;font-weight:600;letter-spacing:.04em;text-transform:uppercase;}
.chip-green{background:var(--green-dim);color:var(--green);border:1px solid rgba(63,185,80,.25);}
.chip-red{background:var(--red-dim);color:var(--red);border:1px solid rgba(248,81,73,.25);}
.chip-gold{background:var(--gold-dim);color:var(--gold);border:1px solid rgba(212,168,67,.25);}
.tag{display:inline-block;font-size:10px;padding:2px 8px;border-radius:99px;font-weight:600;margin-left:6px;}
.tag-blue{background:var(--blue-dim);color:var(--blue);}.tag-gold{background:var(--gold-dim);color:var(--gold);}
.donut-wrap{position:relative;width:130px;height:130px;margin:0 auto 1rem;}
.donut-wrap svg{transform:rotate(-90deg);}
.donut-center{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;}
.dc-val{font-size:1.1rem;font-weight:600;}.dc-label{font-size:10px;color:var(--text3);margin-top:2px;}
.city-btn{height:32px;padding:0 14px;background:var(--bg3);border:1px solid var(--border);border-radius:99px;color:var(--text2);font-family:'DM Sans',sans-serif;font-size:12px;font-weight:500;cursor:pointer;transition:all .15s;}
.city-btn:hover{border-color:var(--border2);color:var(--text);}
.city-btn.active{background:var(--gold-dim);color:var(--gold);border-color:rgba(212,168,67,.35);}
.pr-table{width:100%;border-collapse:collapse;font-size:13px;}
.pr-table th{text-align:left;padding:8px 10px;background:var(--bg3);color:var(--text2);font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;border-bottom:1px solid var(--border);}
.pr-table td{padding:10px;border-bottom:1px solid var(--border);color:var(--text2);}
.pr-table tr:last-child td{border-bottom:none;}
.pr-table tr:hover td{background:var(--bg3);}
.pr-table td:nth-child(3),.pr-table td:nth-child(4){color:var(--gold);font-weight:500;}
.share-box{display:flex;gap:8px;align-items:center;background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius-sm);padding:8px 12px;}
.copy-btn{flex-shrink:0;height:30px;padding:0 14px;background:var(--gold);color:#0d1117;border:none;border-radius:6px;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;cursor:pointer;transition:opacity .15s;}
.copy-btn:hover{opacity:.85;}
.ad-slot{max-width:1100px;margin:0 auto;padding:0 1.5rem 1rem;}
.ad-inner{border:1px solid rgba(255,255,255,.06);border-radius:12px;overflow:hidden;background:#161b22;text-align:center;padding:4px 0;}
.ad-label{font-size:10px;color:var(--text3);letter-spacing:.08em;text-transform:uppercase;padding:6px 0 4px;}
.info-box{background:var(--bg2);border:1px solid var(--border);border-left:3px solid var(--gold);border-radius:var(--radius-sm);padding:.9rem 1.1rem;font-size:13px;color:var(--text2);line-height:1.7;margin-bottom:1rem;}
hr.divider{border:none;border-top:1px solid var(--border);margin:1rem 0;}
.bk-bar-wrap{position:relative;padding-top:40px;margin-bottom:10px;}
.bk-bar-track{height:26px;display:flex;border-radius:6px;overflow:hidden;border:1px solid var(--border);}
.bk-seg{display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;overflow:hidden;white-space:nowrap;transition:flex .45s cubic-bezier(.25,.8,.25,1);}
.bk-seg span{padding:0 5px;pointer-events:none;}
.bk-pin{position:absolute;top:0;display:flex;flex-direction:column;align-items:center;transition:left .45s cubic-bezier(.25,.8,.25,1);}
.bk-pin-label{font-size:10px;font-weight:600;white-space:nowrap;background:var(--bg2);border:1px solid var(--border2);border-radius:4px;padding:2px 7px;color:var(--text);margin-bottom:3px;}
.bk-pin-line{width:1.5px;height:20px;background:var(--text2);border-radius:1px;}
.bk-legend{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:1rem;}
.bk-leg{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--text2);}
.bk-leg-dot{width:8px;height:8px;border-radius:2px;flex-shrink:0;}
.bk-table{width:100%;border-collapse:collapse;font-size:12px;margin-top:2px;}
.bk-table th{text-align:left;padding:6px 10px;background:var(--bg3);color:var(--text3);font-size:10px;font-weight:600;letter-spacing:.07em;text-transform:uppercase;border-bottom:1px solid var(--border);}
.bk-table td{padding:8px 10px;border-bottom:1px solid var(--border);color:var(--text2);font-variant-numeric:tabular-nums;}
.bk-table tr:last-child td{border-bottom:none;}
.bk-table tr.bk-active td{background:rgba(212,168,67,.08);color:var(--text);}
.bk-table tr.bk-active td:first-child{border-left:2px solid var(--gold);}
.bk-table tr.bk-inactive td{opacity:.45;}
.bk-rate-pill{display:inline-block;font-size:10px;font-weight:600;padding:1px 7px;border-radius:99px;}
.income-summary{display:flex;align-items:center;gap:0;background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:.65rem 1.1rem;margin-bottom:1.2rem;flex-wrap:wrap;gap:6px;}
.income-summary .is-item{display:flex;align-items:center;gap:6px;padding:0 12px;border-right:1px solid var(--border);}
.income-summary .is-item:first-child{padding-left:0;}
.income-summary .is-item:last-child{border-right:none;}
.income-summary .is-label{font-size:10px;font-weight:600;letter-spacing:.07em;text-transform:uppercase;color:var(--text3);}
.income-summary .is-value{font-size:13px;font-weight:500;font-variant-numeric:tabular-nums;}
.income-summary .is-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;}
footer{text-align:center;padding:2rem 1.5rem;border-top:1px solid var(--border);font-size:12px;color:var(--text3);line-height:1.8;}
footer a{color:var(--gold);text-decoration:none;}
#cookie-banner{position:fixed;bottom:0;left:0;right:0;z-index:9999;background:#161b22;border-top:1px solid rgba(255,255,255,.1);padding:1rem 1.5rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;}

/* ── PAYSLIP CHECK ── */
.ps-result{display:flex;align-items:flex-start;gap:12px;padding:1rem;border-radius:var(--radius-sm);border:1px solid var(--border);margin-top:1rem;}
.ps-icon{width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.ps-status-ok{background:var(--green-dim);border-color:rgba(63,185,80,.3);}
.ps-status-over{background:var(--blue-dim);border-color:rgba(88,166,255,.3);}
.ps-status-under{background:var(--red-dim);border-color:rgba(248,81,73,.3);}
.ps-title{font-size:14px;font-weight:500;color:var(--text);margin-bottom:3px;}
.ps-desc{font-size:12px;color:var(--text2);line-height:1.6;}

/* ── HOURS LOG ── */
.day-row{display:grid;grid-template-columns:90px 1fr 1fr auto;align-items:center;gap:8px;padding:8px 0;border-bottom:1px solid var(--border);}
.day-row:last-child{border-bottom:none;}
.day-label{font-size:13px;font-weight:500;color:var(--text);}
.day-type{font-size:11px;padding:2px 8px;border-radius:99px;font-weight:600;white-space:nowrap;}
.type-weekday{background:var(--bg3);color:var(--text2);}
.type-saturday{background:var(--blue-dim);color:var(--blue);}
.type-sunday{background:var(--purple-dim);color:var(--purple);}
.type-holiday{background:var(--red-dim);color:var(--red);}
.day-earn{font-size:13px;font-weight:500;color:var(--gold);text-align:right;font-variant-numeric:tabular-nums;}
.ph-toggle{font-size:11px;padding:3px 10px;border-radius:99px;border:1px solid var(--border);background:transparent;color:var(--text2);cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .15s;white-space:nowrap;}
.ph-toggle.active{background:var(--red-dim);color:var(--red);border-color:rgba(248,81,73,.3);}
.tl-hrs-input{width:70px;height:32px;background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text);font-family:'DM Sans',sans-serif;font-size:13px;padding:0 8px;outline:none;text-align:center;-moz-appearance:textfield;transition:border-color .15s;}
.tl-hrs-input::-webkit-outer-spin-button,.tl-hrs-input::-webkit-inner-spin-button{-webkit-appearance:none;}
.tl-hrs-input:focus{border-color:var(--gold);}

/* ── MILESTONES ── */
.milestone-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:1.1rem;transition:border-color .2s;}
.milestone-card:hover{border-color:var(--border2);}
.ms-emoji{font-size:1.6rem;margin-bottom:.5rem;display:block;}
.ms-name{font-size:13px;font-weight:500;color:var(--text);margin-bottom:4px;}
.ms-cost{font-size:11px;color:var(--text3);margin-bottom:.6rem;}
.ms-weeks{font-size:1.2rem;font-weight:500;font-variant-numeric:tabular-nums;margin-bottom:4px;}
.ms-bar-bg{height:6px;background:var(--bg4);border-radius:99px;overflow:hidden;}
.ms-bar-fill{height:100%;border-radius:99px;transition:width .5s cubic-bezier(.25,.8,.25,1);}
.ms-sub{font-size:10px;color:var(--text3);margin-top:4px;}
</style>
</head>
<body>

<header>
  <a href="index.html" class="logo">OzBudget <span>WHV Calculator</span></a>
  <div class="header-nav">
    <a href="about.html">About</a>
    <a href="privacy-policy.html">Privacy</a>
    <div class="header-badge">🇦🇺 2024–25 ATO</div>
    <button class="theme-btn" id="theme-btn" onclick="toggleTheme()" title="Toggle light/dark mode">🌙</button>
  </div>
</header>

<div class="hero">
  <h1>Your <em>complete</em> financial toolkit<br>for working in Australia</h1>
  <p>Tax · Budget · Super · Penalty rates · Payslip check · Hours log · Milestones · Currency · Goal calculator — built for WHV holders (subclass 417 &amp; 462).</p>
</div>

<div class="main-nav">
  <div class="main-nav-tabs">
    <button class="main-tab active" data-tab="income">💰 Income, Tax &amp; Budget</button>
    <button class="main-tab" data-tab="super">🏦 Superannuation</button>
    <button class="main-tab" data-tab="penalty">⏰ Penalty Rates</button>
    <button class="main-tab" data-tab="goal">🎯 Rate Goal</button>
    <button class="main-tab" data-tab="compare">📊 City Compare</button>
    <button class="main-tab" data-tab="currency">💱 Currency</button>
    <button class="main-tab" data-tab="secondyear">🚜 2nd Year Visa</button>
    <button class="main-tab" data-tab="taxreturn">📋 Tax Return</button>
    <button class="main-tab" data-tab="payslip">🧮 Payslip Check</button>
    <button class="main-tab" data-tab="timelog">⏱ Hours Log</button>
    <button class="main-tab" data-tab="milestones">🌏 Milestones</button>
  </div>
</div>

<!-- AD TOP -->
<div class="ad-slot" id="ad-top" style="display:none;">
  <div class="ad-inner"><div class="ad-label">Advertisement</div>
    <ins class="adsbygoogle" style="display:block;" data-ad-client="ca-pub-XXXXXXXXXXXXXXXX" data-ad-slot="XXXXXXXXXX" data-ad-format="auto" data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>
</div>

<!-- TAB: INCOME + BUDGET (merged) -->
<div class="page-section active container" id="tab-income">

  <!-- ROW 1: Income inputs + Tax results -->
  <div class="grid-2" style="margin-bottom:1.5rem;">
    <div class="card">
      <div class="card-title"><div class="ibadge" style="background:rgba(212,168,67,.15);">💰</div>Income Details</div>
      <div class="field"><label>Pay period</label>
        <div class="toggle-group" id="period-toggle">
          <button class="toggle-btn active" data-period="hourly">Hourly</button>
          <button class="toggle-btn" data-period="weekly">Weekly</button>
          <button class="toggle-btn" data-period="fortnightly">Fortnight</button>
          <button class="toggle-btn" data-period="annual">Annual</button>
        </div>
      </div>
      <div class="field"><label id="income-label">Hourly rate (AUD)</label>
        <div class="input-wrap"><span class="pfx">$</span><input type="number" id="income-input" value="25" min="0" step="0.01"></div>
      </div>
      <div class="field" id="hours-field"><label>Hours per week</label>
        <div class="input-wrap"><span class="pfx" style="left:10px;font-size:13px;">h</span><input type="number" id="hours-input" value="38" min="1" max="80" class="no-pfx" style="padding-left:28px;"></div>
      </div>
      <div class="field"><label>Second job (AUD/week, optional)</label>
        <div class="input-wrap"><span class="pfx">$</span><input type="number" id="job2-input" value="0" min="0" step="1"></div>
      </div>
      <div class="field"><label>Medicare Levy</label>
        <div class="toggle-group" id="medicare-toggle">
          <button class="toggle-btn active" data-ml="exempt">Exempt (most WHV)</button>
          <button class="toggle-btn" data-ml="apply">Apply 2%</button>
        </div>
      </div>
      <hr class="divider">
      <div class="card-title" style="margin-bottom:.6rem;"><div class="ibadge" style="background:var(--blue-dim);">📊</div>Tax bracket breakdown</div>

      <div class="bk-bar-wrap">
        <div class="bk-pin" id="bk-pin" style="left:0%;">
          <div class="bk-pin-label" id="bk-pin-label">$0</div>
          <div class="bk-pin-line"></div>
        </div>
        <div class="bk-bar-track" id="bk-bar-track"></div>
      </div>

      <div class="bk-legend" id="bk-legend"></div>

      <div style="border:1px solid var(--border);border-radius:var(--radius-sm);overflow:hidden;">
        <table class="bk-table">
          <thead><tr><th>Bracket</th><th>Rate</th><th>Your slice</th><th>Tax on slice</th><th>Running total</th></tr></thead>
          <tbody id="bk-tbody"></tbody>
        </table>
      </div>
    </div>
    <div style="display:flex;flex-direction:column;gap:1rem;">
      <div class="grid-2" style="gap:10px;">
        <div class="metric"><div class="m-label">Annual gross</div><div class="m-value c-gold" id="r-gross">$0</div><div class="m-sub" id="r-gross-wk">$0 / week</div></div>
        <div class="metric"><div class="m-label">Tax withheld</div><div class="m-value c-red" id="r-tax">$0</div><div class="m-sub" id="r-eff">0.0% effective</div></div>
        <div class="metric"><div class="m-label">Medicare levy</div><div class="m-value" id="r-ml">$0</div><div class="m-sub">Annual</div></div>
        <div class="metric"><div class="m-label">Annual net</div><div class="m-value c-green" id="r-net">$0</div><div class="m-sub" id="r-net-wk">$0 / week</div></div>
        <div class="metric"><div class="m-label">Monthly net</div><div class="m-value c-blue" id="r-net-mo">$0</div><div class="m-sub">After tax</div></div>
        <div class="metric"><div class="m-label">Employer super</div><div class="m-value c-purple" id="r-super">$0</div><div class="m-sub">11.5% on top</div></div>
      </div>
      <div class="card">
        <div class="card-title" style="margin-bottom:.8rem;"><div class="ibadge" style="background:var(--blue-dim);">🔗</div>Share your setup</div>
        <div class="share-box"><span id="share-url" style="flex:1;font-size:11px;color:var(--text2);word-break:break-all;">—</span><button class="copy-btn" onclick="copyShareUrl()">Copy</button></div>
        <p style="font-size:11px;color:var(--text3);margin-top:6px;">URL encodes all your income &amp; expense values.</p>
      </div>
    </div>
  </div>

  <!-- ROW 2: Expenses + Budget summary -->
  <div class="grid-2">
    <div class="card">
      <div class="card-title"><div class="ibadge" style="background:rgba(248,81,73,.12);">🧾</div>Monthly Expenses</div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:1rem;">
        <span style="font-size:12px;color:var(--text2);align-self:center;">City preset:</span>
        <button class="city-btn" data-city="sydney">🏙 Sydney</button>
        <button class="city-btn" data-city="melbourne">🏛 Melbourne</button>
        <button class="city-btn" data-city="brisbane">☀️ Brisbane</button>
        <button class="city-btn" data-city="perth">🌊 Perth</button>
        <button class="city-btn" data-city="regional">🌾 Regional</button>
      </div>
      <div id="expense-list"></div>
      <hr class="divider" style="margin-top:.5rem;">
      <div class="brow"><div class="brow-label"><strong>Total monthly</strong></div><div class="brow-val c-red" id="total-exp-mo">$0</div></div>
      <div class="brow"><div class="brow-label">Total annual</div><div class="brow-val c-red" id="total-exp-yr">$0</div></div>
    </div>
    <div style="display:flex;flex-direction:column;gap:1rem;">
      <div class="card">
        <div class="card-title" style="margin-bottom:.8rem;"><div class="ibadge" style="background:var(--green-dim);">📈</div>Budget Summary</div>
        <div style="display:grid;grid-template-columns:130px 1fr;gap:1.5rem;align-items:center;">
          <div>
            <div class="donut-wrap">
              <svg width="130" height="130" viewBox="0 0 130 130"><circle cx="65" cy="65" r="52" stroke="#21262d" stroke-width="14" fill="none"/><circle id="donut-tax" cx="65" cy="65" r="52" stroke="#f85149" stroke-width="14" fill="none" stroke-linecap="round" stroke-dasharray="326.7" stroke-dashoffset="326.7"/><circle id="donut-exp" cx="65" cy="65" r="52" stroke="#d4a843" stroke-width="14" fill="none" stroke-linecap="round" stroke-dasharray="326.7" stroke-dashoffset="326.7"/><circle id="donut-sav" cx="65" cy="65" r="52" stroke="#3fb950" stroke-width="14" fill="none" stroke-linecap="round" stroke-dasharray="326.7" stroke-dashoffset="326.7"/></svg>
              <div class="donut-center"><div class="dc-val c-green" id="donut-pct">0%</div><div class="dc-label">saved</div></div>
            </div>
            <div style="font-size:11px;color:var(--text3);text-align:center;line-height:2;">
              <span style="color:var(--red);">■</span> Tax &nbsp;<span style="color:var(--gold);">■</span> Expenses &nbsp;<span style="color:var(--green);">■</span> Savings
            </div>
          </div>
          <div>
            <div class="grid-2" style="gap:8px;margin-bottom:.8rem;">
              <div class="metric"><div class="m-label">Monthly net</div><div class="m-value c-gold" id="s-mo-net">$0</div></div>
              <div class="metric"><div class="m-label">Monthly spend</div><div class="m-value c-red" id="s-mo-spend">$0</div></div>
              <div class="metric span-full"><div class="m-label">Monthly savings</div><div class="m-value" id="s-mo-save">$0</div><div class="m-sub" id="s-save-pct">0% of income</div></div>
            </div>
            <div class="bar-bg"><div class="bar-fill" id="exp-bar"></div></div>
            <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--text3);margin-bottom:.8rem;"><span>Expenses as % of net</span><span id="exp-pct-label">0%</span></div>
            <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
              <span id="status-chip" class="chip chip-green">● Healthy</span>
              <span style="font-size:12px;color:var(--text3);" id="status-msg"></span>
            </div>
          </div>
        </div>
      </div>
      <div class="card">
        <div class="card-title" style="margin-bottom:.8rem;"><div class="ibadge" style="background:var(--green-dim);">🎯</div>Savings projection</div>
        <div class="grid-4">
          <div class="metric"><div class="m-label">3 months</div><div class="m-value c-green" id="proj-3">$0</div></div>
          <div class="metric"><div class="m-label">6 months</div><div class="m-value c-green" id="proj-6">$0</div></div>
          <div class="metric"><div class="m-label">9 months</div><div class="m-value c-green" id="proj-9">$0</div></div>
          <div class="metric"><div class="m-label">12 months</div><div class="m-value c-green" id="proj-12">$0</div></div>
        </div>
      </div>
    </div>
  </div>

</div>

<!-- TAB: SUPER -->
<div class="page-section container" id="tab-super">
  <div class="income-summary">
    <div class="is-item"><div class="is-dot" style="background:var(--gold);"></div><span class="is-label">Annual gross</span><span class="is-value c-gold" id="is-gross-super">$0</span></div>
    <div class="is-item"><div class="is-dot" style="background:var(--red);"></div><span class="is-label">Tax</span><span class="is-value c-red" id="is-tax-super">$0</span></div>
    <div class="is-item"><div class="is-dot" style="background:var(--green);"></div><span class="is-label">Annual net</span><span class="is-value c-green" id="is-net-super">$0</span></div>
    <div class="is-item"><div class="is-dot" style="background:var(--blue);"></div><span class="is-label">Weekly net</span><span class="is-value c-blue" id="is-wknet-super">$0</span></div>
    <div class="is-item" style="margin-left:auto;border-right:none;"><span class="is-label" style="color:var(--text3);">↖ From Income &amp; Tax tab</span></div>
  </div>
  <div class="grid-2">
    <div class="card">
      <div class="card-title"><div class="ibadge" style="background:var(--purple-dim);">🏦</div>Super Calculator</div>
      <div class="info-box">Your employer must contribute <strong>11.5%</strong> of your earnings to super. When you leave Australia permanently, claim it back as a DASP — but WHV holders are taxed at <strong>65%</strong> on withdrawal.</div>
      <div class="field"><label>Weeks worked in Australia</label>
        <div class="input-wrap"><span class="pfx" style="font-size:12px;left:10px;">wk</span><input type="number" id="super-weeks" value="26" min="1" max="104" class="no-pfx" style="padding-left:30px;"></div>
      </div>
      <div class="field"><label>Employer super rate</label>
        <div class="toggle-group" id="super-rate-toggle">
          <button class="toggle-btn active" data-rate="0.115">11.5% (current)</button>
          <button class="toggle-btn" data-rate="0.12">12% (from Jul 25)</button>
        </div>
      </div>
    </div>
    <div style="display:flex;flex-direction:column;gap:1rem;">
      <div class="grid-2" style="gap:10px;">
        <div class="metric"><div class="m-label">Gross super accrued</div><div class="m-value c-purple" id="sup-gross">$0</div><div class="m-sub">Employer contributions</div></div>
        <div class="metric"><div class="m-label">DASP tax (65%)</div><div class="m-value c-red" id="sup-tax">$0</div><div class="m-sub">Withheld on claim</div></div>
        <div class="metric"><div class="m-label">You receive (DASP)</div><div class="m-value c-green" id="sup-net">$0</div><div class="m-sub">After DASP tax</div></div>
        <div class="metric"><div class="m-label">Weekly contribution</div><div class="m-value c-purple" id="sup-weekly">$0</div><div class="m-sub">Accruing per week</div></div>
      </div>
      <div class="card">
        <div class="card-title" style="margin-bottom:.6rem;"><div class="ibadge" style="background:var(--purple-dim);">💡</div>How to claim DASP</div>
        <div style="font-size:13px;color:var(--text2);line-height:1.9;">
          <p style="margin-bottom:.4rem;">1. Leave Australia permanently (or let your visa expire)</p>
          <p style="margin-bottom:.4rem;">2. Wait 6 months after your visa expires</p>
          <p style="margin-bottom:.4rem;">3. Apply online at <strong style="color:var(--text);">ato.gov.au/DASP</strong></p>
          <p>Ensure your fund has your Tax File Number to avoid extra withholding.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- TAB: PENALTY RATES -->
<div class="page-section container" id="tab-penalty">
  <div class="income-summary">
    <div class="is-item"><div class="is-dot" style="background:var(--gold);"></div><span class="is-label">Annual gross</span><span class="is-value c-gold" id="is-gross-penalty">$0</span></div>
    <div class="is-item"><div class="is-dot" style="background:var(--red);"></div><span class="is-label">Tax</span><span class="is-value c-red" id="is-tax-penalty">$0</span></div>
    <div class="is-item"><div class="is-dot" style="background:var(--green);"></div><span class="is-label">Annual net</span><span class="is-value c-green" id="is-net-penalty">$0</span></div>
    <div class="is-item"><div class="is-dot" style="background:var(--blue);"></div><span class="is-label">Hourly (after tax)</span><span class="is-value c-blue" id="is-hrly-penalty">$0</span></div>
    <div class="is-item" style="margin-left:auto;border-right:none;"><span class="is-label" style="color:var(--text3);">↖ From Income &amp; Tax tab</span></div>
  </div>
  <div class="grid-2">
    <div class="card">
      <div class="card-title"><div class="ibadge" style="background:rgba(212,168,67,.15);">⏰</div>Penalty Rate Calculator</div>
      <div class="info-box">Under Hospitality, Retail, and Fast Food awards — common WHV industries — you're legally entitled to penalty rates for evenings, weekends, and public holidays.</div>
      <div class="field"><label>Your base hourly rate (AUD)</label>
        <div class="input-wrap"><span class="pfx">$</span><input type="number" id="pr-base" value="25" min="0" step="0.01"></div>
      </div>
      <div class="field"><label>Award / industry</label>
        <select id="pr-award">
          <option value="hospitality">Hospitality</option>
          <option value="retail">Retail</option>
          <option value="fastfood">Fast Food</option>
          <option value="farm">Farm / Horticulture</option>
        </select>
      </div>
    </div>
    <div class="card">
      <div class="card-title" style="margin-bottom:.8rem;"><div class="ibadge" style="background:rgba(212,168,67,.15);">📋</div>Your penalty rates</div>
      <table class="pr-table"><thead><tr><th>Period</th><th>Multiplier</th><th>Your rate</th><th>8 hrs earns</th></tr></thead><tbody id="pr-tbody"></tbody></table>
    </div>
  </div>
</div>

<!-- TAB: GOAL -->
<div class="page-section container" id="tab-goal">
  <div class="income-summary">
    <div class="is-item"><div class="is-dot" style="background:var(--gold);"></div><span class="is-label">Current annual gross</span><span class="is-value c-gold" id="is-gross-goal">$0</span></div>
    <div class="is-item"><div class="is-dot" style="background:var(--green);"></div><span class="is-label">Current annual net</span><span class="is-value c-green" id="is-net-goal">$0</span></div>
    <div class="is-item"><div class="is-dot" style="background:var(--blue);"></div><span class="is-label">Monthly net</span><span class="is-value c-blue" id="is-monet-goal">$0</span></div>
    <div class="is-item"><div class="is-dot" style="background:var(--red);"></div><span class="is-label">Monthly expenses</span><span class="is-value c-red" id="is-exp-goal">$0</span></div>
    <div class="is-item" style="margin-left:auto;border-right:none;"><span class="is-label" style="color:var(--text3);">↖ From Income &amp; Tax tab</span></div>
  </div>
  <div class="grid-2">
    <div class="card">
      <div class="card-title"><div class="ibadge" style="background:var(--green-dim);">🎯</div>Savings Goal Calculator</div>
      <p style="font-size:13px;color:var(--text2);margin-bottom:1rem;">Enter your target — we'll reverse-calculate the hourly rate and hours per week needed to hit it.</p>
      <div class="field"><label>Savings goal (AUD)</label>
        <div class="input-wrap"><span class="pfx">$</span><input type="number" id="goal-amount" value="10000" min="0" step="100"></div>
      </div>
      <div class="field"><label>Timeframe (months)</label>
        <div class="input-wrap"><span class="pfx" style="left:10px;font-size:12px;">mo</span><input type="number" id="goal-months" value="6" min="1" max="24" class="no-pfx" style="padding-left:30px;"></div>
      </div>
      <div class="field"><label>Monthly expenses (auto-synced from Budget tab)</label>
        <div class="input-wrap"><span class="pfx">$</span><input type="number" id="goal-expenses" value="2220" min="0" step="10"></div>
      </div>
    </div>
    <div style="display:flex;flex-direction:column;gap:1rem;">
      <div class="grid-2" style="gap:10px;">
        <div class="metric"><div class="m-label">Monthly net needed</div><div class="m-value c-gold" id="goal-mo-net">$0</div><div class="m-sub">Expenses + savings</div></div>
        <div class="metric"><div class="m-label">Annual gross needed</div><div class="m-value c-gold" id="goal-gross">$0</div></div>
        <div class="metric"><div class="m-label">Hourly rate needed</div><div class="m-value c-green" id="goal-rate">$0/hr</div><div class="m-sub">At 38 hrs/week</div></div>
        <div class="metric"><div class="m-label">Hours/week needed</div><div class="m-value c-blue" id="goal-hours">0 hrs</div><div class="m-sub">At your current rate</div></div>
      </div>
      <div class="card">
        <div class="card-title" style="margin-bottom:.6rem;"><div class="ibadge" style="background:var(--green-dim);">📐</div>Breakdown</div>
        <div id="goal-breakdown"></div>
      </div>
    </div>
  </div>
</div>

<!-- TAB: CITY COMPARE -->
<div class="page-section container" id="tab-compare">
  <div class="income-summary">
    <div class="is-item"><div class="is-dot" style="background:var(--gold);"></div><span class="is-label">Annual gross</span><span class="is-value c-gold" id="is-gross-compare">$0</span></div>
    <div class="is-item"><div class="is-dot" style="background:var(--green);"></div><span class="is-label">Monthly net</span><span class="is-value c-green" id="is-monet-compare">$0</span></div>
    <div class="is-item"><div class="is-dot" style="background:var(--red);"></div><span class="is-label">Tax rate</span><span class="is-value c-red" id="is-taxrate-compare">0%</span></div>
    <div class="is-item" style="margin-left:auto;border-right:none;"><span class="is-label" style="color:var(--text3);">↖ From Income &amp; Tax tab</span></div>
  </div>
  <div class="card" style="margin-bottom:1rem;">
    <div class="card-title"><div class="ibadge" style="background:var(--blue-dim);">📊</div>City vs City Comparison</div>
    <p style="font-size:13px;color:var(--text2);">How your budget holds up in different Australian cities — using your income from the Income tab.</p>
  </div>
  <div style="display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:1rem;" id="city-compare-grid"></div>
</div>

<!-- TAB: CURRENCY -->
<div class="page-section container" id="tab-currency">
  <div class="income-summary">
    <div class="is-item"><div class="is-dot" style="background:var(--gold);"></div><span class="is-label">Annual gross (AUD)</span><span class="is-value c-gold" id="is-gross-currency">$0</span></div>
    <div class="is-item"><div class="is-dot" style="background:var(--green);"></div><span class="is-label">Annual net (AUD)</span><span class="is-value c-green" id="is-net-currency">$0</span></div>
    <div class="is-item"><div class="is-dot" style="background:var(--blue);"></div><span class="is-label">Weekly net (AUD)</span><span class="is-value c-blue" id="is-wknet-currency">$0</span></div>
    <div class="is-item" style="margin-left:auto;border-right:none;"><span class="is-label" style="color:var(--text3);">↖ From Income &amp; Tax tab</span></div>
  </div>
  <div class="grid-2">
    <div class="card">
      <div class="card-title"><div class="ibadge" style="background:var(--teal-dim);">💱</div>Currency Converter</div>
      <p style="font-size:13px;color:var(--text2);margin-bottom:1rem;">See your Australian income in your home currency. Rates are approximate — verify with your bank.</p>
      <div class="field"><label>Your home currency</label>
        <select id="currency-select">
          <option value="GBP">🇬🇧 British Pound (GBP)</option>
          <option value="EUR">🇪🇺 Euro (EUR)</option>
          <option value="USD">🇺🇸 US Dollar (USD)</option>
          <option value="PHP">🇵🇭 Philippine Peso (PHP)</option>
          <option value="JPY">🇯🇵 Japanese Yen (JPY)</option>
          <option value="KRW">🇰🇷 Korean Won (KRW)</option>
          <option value="NZD">🇳🇿 New Zealand Dollar (NZD)</option>
          <option value="CAD">🇨🇦 Canadian Dollar (CAD)</option>
          <option value="ZAR">🇿🇦 South African Rand (ZAR)</option>
          <option value="BRL">🇧🇷 Brazilian Real (BRL)</option>
          <option value="MXN">🇲🇽 Mexican Peso (MXN)</option>
          <option value="SGD">🇸🇬 Singapore Dollar (SGD)</option>
          <option value="HKD">🇭🇰 Hong Kong Dollar (HKD)</option>
          <option value="INR">🇮🇳 Indian Rupee (INR)</option>
          <option value="THB">🇹🇭 Thai Baht (THB)</option>
          <option value="TWD">🇹🇼 Taiwan Dollar (TWD)</option>
        </select>
      </div>
      <div class="field"><label>Exchange rate (1 AUD = ? <span id="fx-curr-label">GBP</span>)</label>
        <div class="input-wrap"><input type="number" id="fx-rate" value="0.51" min="0.001" step="0.001" class="no-pfx"></div>
        <p style="font-size:11px;color:var(--text3);margin-top:5px;">Update with today's rate from Google or your bank.</p>
      </div>
    </div>
    <div style="display:flex;flex-direction:column;gap:1rem;">
      <div class="grid-2" style="gap:10px;">
        <div class="metric"><div class="m-label">Annual gross</div><div class="m-value c-gold" id="fx-gross">0</div><div class="m-sub" id="fx-gross-aud"></div></div>
        <div class="metric"><div class="m-label">Annual net</div><div class="m-value c-green" id="fx-net">0</div><div class="m-sub" id="fx-net-aud"></div></div>
        <div class="metric"><div class="m-label">Weekly take-home</div><div class="m-value c-blue" id="fx-weekly">0</div><div class="m-sub" id="fx-weekly-aud"></div></div>
        <div class="metric"><div class="m-label">Monthly savings</div><div class="m-value c-teal" id="fx-savings">0</div><div class="m-sub" id="fx-savings-aud"></div></div>
      </div>
      <div class="card">
        <div class="card-title" style="margin-bottom:.4rem;"><div class="ibadge" style="background:var(--teal-dim);">⚡</div>Hourly in your currency</div>
