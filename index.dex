        <div class="metric"><div class="m-label">Tax withheld</div><div class="m-value c-red" id="ps-r-withheld">$0</div><div class="m-sub">By employer</div></div>
        <div class="metric"><div class="m-label">Tax should be</div><div class="m-value c-blue" id="ps-r-correct">$0</div><div class="m-sub">Per ATO WHV rate</div></div>
        <div class="metric"><div class="m-label">Difference</div><div class="m-value" id="ps-r-diff">$0</div><div class="m-sub" id="ps-r-diff-sub">—</div></div>
      </div>
      <div id="ps-verdict"></div>
